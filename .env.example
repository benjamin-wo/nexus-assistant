# Telegram Bot API token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# LLM Provider: gemini | deepseek | openrouter
LLM_PROVIDER=gemini

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Selected models for each provider (optional, defaults will be used)
GEMINI_MODEL=gemini-2.5-flash
DEEPSEEK_MODEL=deepseek-chat
OPENROUTER_MODEL=nousresearch/hermes-3-llama-3-8b

# Storage connection string (optional: if omitted, SQLite is used locally)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=
